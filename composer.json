{
    "name": "andydefer/authentication-kit",
    "description": "Headless authentication kit for Laravel built on Nemesis and Laravel Actions",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Defer",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "andydefer/directive-forge": "^2.9.9",
        "jenssegers/agent": "^2.6",
        "andydefer/laravel-nemesis": "^1.9.0",
        "andydefer/laravel-otp": "^1.0.7",
        "andydefer/laravel-notification": "^1.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29",
        "laravel/tinker": "^2.11"
    },
    "autoload": {
        "psr-4": {
            "AndyDefer\\AuthenticationKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\AuthenticationKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AndyDefer\\AuthenticationKit\\AuthenticationKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
